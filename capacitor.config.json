{
  "appId": "com.inuslabs.pikko",
  "appName": "Pikko",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#1A1A2E",
      "androidSplashResourceName": "splash",
      "showSpinner": false
